{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OppoKodiAddon Configurator",
  "version": "0.5.0",
  "identifier": "com.script-oppo203-iso-external.configurator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OppoKodiAddon Configurator",
        "label": "main",
        "width": 1180,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 720,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
