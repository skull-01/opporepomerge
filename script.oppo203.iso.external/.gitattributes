# Git hooks are executed by sh/bash; they must keep LF endings even on Windows
# (a CRLF in the shebang line breaks `#!/usr/bin/env bash`).
scripts/hooks/* text eol=lf

# Cargo writes Cargo.lock with LF endings; without this, autocrlf=true on
# Windows checks out CRLF, cargo rewrites LF, and every cargo invocation
# shows a phantom diff.
Cargo.lock text eol=lf
